    "terminal.ansiBrightYellow": "#f1bf02",
    "terminal.ansiBrightBlue": "#9963ff",
    "terminal.ansiBrightMagenta": "#d21e85",
    "terminal.ansiBrightCyan": "#b059b1",
    "terminal.ansiBrightWhite": "#ffffff",
